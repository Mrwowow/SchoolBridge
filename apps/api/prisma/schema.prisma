// ─── Prisma Schema — SchoolBridge ───────────────────────────────────────────
// Multi-tenant school communication platform.
// Each School is a tenant; all cross-tenant data is scoped by schoolId.
// IDs use cuid() for URL-safe, time-ordered identifiers.
// Soft-delete is applied via deletedAt where sensible (users, pupils, messages).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums (mirror @schoolbridge/types) ─────────────────────────────────────

enum Role {
  SUPER_ADMIN
  SCHOOL_ADMIN
  CLASS_TEACHER
  TEACHER
  PARENT
}

enum MessageType {
  NOTE
  HOMEWORK
  BEHAVIOUR
  ATTENDANCE
  RESULT
  ANNOUNCEMENT
  FEE_REMINDER
  EVENT
}

enum MessageTarget {
  PUPIL
  CLASS
  SCHOOL
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum BehaviourLevel {
  NEEDS_WORK
  GOOD
  EXCELLENT
}

enum NotificationChannel {
  PUSH
  SMS
  EMAIL
  IN_APP
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  DELIVERED
}

enum SchoolPlan {
  TRIAL
  BASIC
  STANDARD
  PREMIUM
}

enum SchoolStatus {
  ACTIVE
  SUSPENDED
  CHURNED
}

enum GuardianRelationship {
  FATHER
  MOTHER
  GUARDIAN
  SIBLING
  OTHER
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  TRIALING
}

enum BillingInterval {
  MONTHLY
  YEARLY
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

// ─── School (tenant root) ───────────────────────────────────────────────────

model School {
  id        String       @id @default(cuid())
  name      String
  slug      String       @unique
  plan      SchoolPlan   @default(TRIAL)
  status    SchoolStatus @default(ACTIVE)
  /// Flexible settings bag: address, logo URL, timezone, etc.
  settings  Json         @default("{}")
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  memberships      Membership[]
  academicYears    AcademicYear[]
  classRooms       ClassRoom[]
  subjects         Subject[]
  pupils           Pupil[]
  messages         Message[]
  notifications    Notification[]
  subscriptions    Subscription[]
  auditLogs        AuditLog[]
  feeInvoices      FeeInvoice[]
  daySubjectNotes  DaySubjectNote[]
  behaviourRatings BehaviourRating[]
  pupilBadges      PupilBadge[]

  @@index([status])
  @@map("schools")
}

// ─── User ───────────────────────────────────────────────────────────────────

model User {
  id              String    @id @default(cuid())
  fullName        String
  phone           String    @unique
  email           String?   @unique
  passwordHash    String
  locale          String    @default("en")
  /// Null until phone is verified via OTP
  phoneVerifiedAt DateTime?
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  memberships      Membership[]
  otpCodes         OtpCode[]
  guardianLinks    GuardianLink[]
  authoredMessages Message[]      @relation("MessageAuthor")
  replies          Reply[]
  notifications    Notification[]
  auditLogs        AuditLog[]
  refreshTokens    RefreshToken[]
  deviceTokens     DeviceToken[]

  @@index([phone])
  @@index([email])
  @@index([deletedAt])
  @@map("users")
}

// ─── DeviceToken (Expo push tokens per user device) ─────────────────────────

model DeviceToken {
  id         String   @id @default(cuid())
  userId     String
  token      String   @unique
  platform   String? // ios | android | web
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("device_tokens")
}

// ─── Membership (User ↔ School ↔ Role) ─────────────────────────────────────

model Membership {
  id       String   @id @default(cuid())
  userId   String
  schoolId String
  role     Role
  joinedAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([userId, schoolId, role])
  @@index([schoolId])
  @@index([userId])
  @@map("memberships")
}

// ─── Auth: OTP + Refresh Tokens ─────────────────────────────────────────────

model OtpCode {
  id        String    @id @default(cuid())
  userId    String
  code      String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("otp_codes")
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

// ─── Academic Structure ──────────────────────────────────────────────────────

model AcademicYear {
  id        String   @id @default(cuid())
  schoolId  String
  label     String // e.g. "2024/2025"
  startDate DateTime
  endDate   DateTime
  isCurrent Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  terms  Term[]

  @@unique([schoolId, label])
  @@index([schoolId, isCurrent])
  @@map("academic_years")
}

model Term {
  id             String   @id @default(cuid())
  academicYearId String
  schoolId       String
  label          String // e.g. "First Term"
  startDate      DateTime
  endDate        DateTime
  isCurrent      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  academicYear      AcademicYear       @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  attendances       Attendance[]
  assessmentResults AssessmentResult[]

  @@unique([academicYearId, label])
  @@index([schoolId, isCurrent])
  @@map("terms")
}

// ─── ClassRoom ───────────────────────────────────────────────────────────────

model ClassRoom {
  id             String   @id @default(cuid())
  schoolId       String
  name           String // e.g. "JSS 1A"
  classTeacherId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  school      School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  enrollments Enrollment[]
  messages    Message[]
  attendances Attendance[]

  @@unique([schoolId, name])
  @@index([schoolId])
  @@map("class_rooms")
}

// ─── Subject ─────────────────────────────────────────────────────────────────

model Subject {
  id        String   @id @default(cuid())
  schoolId  String
  name      String
  createdAt DateTime @default(now())

  school            School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  assessmentResults AssessmentResult[]
  daySubjectNotes   DaySubjectNote[]

  @@unique([schoolId, name])
  @@index([schoolId])
  @@map("subjects")
}

// ─── Pupil ───────────────────────────────────────────────────────────────────

model Pupil {
  id          String    @id @default(cuid())
  schoolId    String
  fullName    String
  dateOfBirth DateTime?
  gender      String?
  admissionNo String?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  school              School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  guardianLinks       GuardianLink[]
  enrollments         Enrollment[]
  messages            Message[]
  messageReceipts     MessageReceipt[]
  attendances         Attendance[]
  assessmentResults   AssessmentResult[]
  feeInvoices         FeeInvoice[]
  daySubjectNotes     DaySubjectNote[]
  behaviourRatings    BehaviourRating[]
  homeworkSubmissions HomeworkSubmission[]
  badges              PupilBadge[]

  @@unique([schoolId, admissionNo])
  @@index([schoolId])
  @@index([deletedAt])
  @@map("pupils")
}

// ─── Guardian Link (Pupil ↔ User w/ relationship) ────────────────────────────

model GuardianLink {
  id           String               @id @default(cuid())
  pupilId      String
  userId       String
  relationship GuardianRelationship @default(GUARDIAN)
  isPrimary    Boolean              @default(false)
  createdAt    DateTime             @default(now())

  pupil Pupil @relation(fields: [pupilId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([pupilId, userId])
  @@index([userId])
  @@index([pupilId])
  @@map("guardian_links")
}

// ─── Enrollment (Pupil ↔ ClassRoom per term) ────────────────────────────────

model Enrollment {
  id          String    @id @default(cuid())
  pupilId     String
  classRoomId String
  enrolledAt  DateTime  @default(now())
  leftAt      DateTime?

  pupil     Pupil     @relation(fields: [pupilId], references: [id], onDelete: Cascade)
  classRoom ClassRoom @relation(fields: [classRoomId], references: [id], onDelete: Cascade)

  @@unique([pupilId, classRoomId])
  @@index([classRoomId])
  @@map("enrollments")
}

// ─── Message (digital booklet entry) ────────────────────────────────────────

model Message {
  id          String        @id @default(cuid())
  schoolId    String
  authorId    String
  type        MessageType
  target      MessageTarget
  /// Populated when target = PUPIL
  pupilId     String?
  /// Populated when target = CLASS
  classRoomId String?
  title       String
  body        String?
  /// Object-store keys for uploaded attachments
  attachments String[]      @default([])
  /// Object-store key / URL for a voice note, when this entry is audio.
  audioUrl    String?
  dueAt       DateTime?
  deletedAt   DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  school      School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  author      User                 @relation("MessageAuthor", fields: [authorId], references: [id])
  pupil       Pupil?               @relation(fields: [pupilId], references: [id])
  classRoom   ClassRoom?           @relation(fields: [classRoomId], references: [id])
  receipts    MessageReceipt[]
  replies     Reply[]
  submissions HomeworkSubmission[]

  @@index([schoolId, createdAt(sort: Desc)])
  @@index([schoolId, pupilId])
  @@index([schoolId, classRoomId])
  @@index([authorId])
  @@index([deletedAt])
  @@map("messages")
}

// ─── MessageReceipt (per-recipient read/ack tracking) ───────────────────────

model MessageReceipt {
  id             String    @id @default(cuid())
  messageId      String
  pupilId        String
  deliveredAt    DateTime?
  readAt         DateTime?
  acknowledgedAt DateTime?
  createdAt      DateTime  @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  pupil   Pupil   @relation(fields: [pupilId], references: [id], onDelete: Cascade)

  @@unique([messageId, pupilId])
  @@index([pupilId])
  @@map("message_receipts")
}

// ─── Reply (threaded on Message) ─────────────────────────────────────────────

model Reply {
  id        String   @id @default(cuid())
  messageId String
  authorId  String
  body      String
  /// Object-store key / URL for a voice-note reply, when audio.
  audioUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  author  User    @relation(fields: [authorId], references: [id])

  @@index([messageId])
  @@index([authorId])
  @@map("replies")
}

// ─── Attendance ──────────────────────────────────────────────────────────────

model Attendance {
  id          String           @id @default(cuid())
  schoolId    String
  termId      String
  classRoomId String
  pupilId     String
  date        DateTime         @db.Date
  status      AttendanceStatus
  note        String?
  /// Free-text mood captured at register time (e.g. "Cheerful"). Optional.
  mood        String?
  /// When the pupil arrived (for "arrived 7:42 AM" on the parent home).
  arrivedAt   DateTime?
  recordedBy  String
  createdAt   DateTime         @default(now())

  term      Term      @relation(fields: [termId], references: [id])
  classRoom ClassRoom @relation(fields: [classRoomId], references: [id])
  pupil     Pupil     @relation(fields: [pupilId], references: [id])

  @@unique([pupilId, date])
  @@index([classRoomId, date])
  @@index([termId])
  @@map("attendances")
}

// ─── AssessmentResult ────────────────────────────────────────────────────────

model AssessmentResult {
  id        String   @id @default(cuid())
  schoolId  String
  termId    String
  pupilId   String
  subjectId String
  score     Decimal  @db.Decimal(5, 2)
  maxScore  Decimal  @db.Decimal(5, 2)
  grade     String?
  remarks   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  term    Term    @relation(fields: [termId], references: [id])
  pupil   Pupil   @relation(fields: [pupilId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])

  @@unique([termId, pupilId, subjectId])
  @@index([pupilId])
  @@index([termId])
  @@map("assessment_results")
}

// ─── DaySubjectNote (per-subject classwork entry for a pupil's day) ──────────
// Powers the parent "Today" report: one row per subject taught that day.

model DaySubjectNote {
  id        String   @id @default(cuid())
  schoolId  String
  pupilId   String
  subjectId String
  date      DateTime @db.Date
  /// What was covered, e.g. "Long division (3-digit numbers)".
  topic     String
  /// Teacher's short note, e.g. "Led her group".
  note      String?
  /// Optional classwork score shown as "8/10".
  score     Int?
  maxScore  Int?
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school  School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  pupil   Pupil   @relation(fields: [pupilId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id])

  @@unique([pupilId, subjectId, date])
  @@index([schoolId, pupilId, date])
  @@map("day_subject_notes")
}

// ─── BehaviourRating (per-pupil daily behaviour scorecard) ──────────────────
// Powers the report's "Participation & behaviour" rating rows.

model BehaviourRating {
  id        String         @id @default(cuid())
  schoolId  String
  pupilId   String
  date      DateTime       @db.Date
  /// Rating dimension, e.g. "Class participation", "Focus & attention".
  label     String
  value     BehaviourLevel
  createdBy String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  pupil  Pupil  @relation(fields: [pupilId], references: [id], onDelete: Cascade)

  @@unique([pupilId, date, label])
  @@index([schoolId, pupilId, date])
  @@map("behaviour_ratings")
}

// ─── HomeworkSubmission (pupil submitted a HOMEWORK message) ─────────────────
// Powers teacher "submitted / total" counts and the parent "done" checkbox.

model HomeworkSubmission {
  id          String   @id @default(cuid())
  messageId   String
  pupilId     String
  submittedAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  pupil   Pupil   @relation(fields: [pupilId], references: [id], onDelete: Cascade)

  @@unique([messageId, pupilId])
  @@index([pupilId])
  @@map("homework_submissions")
}

// ─── PupilBadge (milestones shown on the pupil profile) ─────────────────────

model PupilBadge {
  id        String   @id @default(cuid())
  schoolId  String
  pupilId   String
  /// Icon key understood by the mobile design system, e.g. "book", "star".
  icon      String
  label     String
  /// Sub-text, e.g. "12 days", "Mathematics".
  sub       String?
  createdAt DateTime @default(now())

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  pupil  Pupil  @relation(fields: [pupilId], references: [id], onDelete: Cascade)

  @@index([pupilId])
  @@map("pupil_badges")
}

// ─── FeeInvoice & Payment ────────────────────────────────────────────────────

model FeeInvoice {
  id          String        @id @default(cuid())
  schoolId    String
  pupilId     String
  description String
  amountKobo  BigInt
  dueAt       DateTime
  status      PaymentStatus @default(PENDING)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  school   School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  pupil    Pupil     @relation(fields: [pupilId], references: [id])
  payments Payment[]

  @@index([schoolId])
  @@index([pupilId])
  @@map("fee_invoices")
}

model Payment {
  id              String        @id @default(cuid())
  feeInvoiceId    String
  reference       String        @unique
  amountKobo      BigInt
  status          PaymentStatus @default(PENDING)
  /// Paystack or other gateway name
  gateway         String        @default("paystack")
  gatewayMetadata Json          @default("{}")
  paidAt          DateTime?
  createdAt       DateTime      @default(now())

  feeInvoice FeeInvoice @relation(fields: [feeInvoiceId], references: [id])

  @@index([feeInvoiceId])
  @@map("payments")
}

// ─── Subscription (school billing) ──────────────────────────────────────────

// ─── Plan catalog ────────────────────────────────────────────────────────────
// One row per SchoolPlan tier. Defines what each tier costs and offers; the
// Super Admin edits these. School.plan / Subscription.plan reference the tier
// key, this model gives that key its price, limits and description.

model Plan {
  tier            SchoolPlan      @id
  name            String
  description     String          @default("")
  /// Price in whole Naira (NGN) for one billing interval. 0 = free (e.g. TRIAL).
  priceNaira      Int             @default(0)
  billingInterval BillingInterval @default(MONTHLY)
  /// Feature limits. null = unlimited.
  maxPupils       Int?
  maxStaff        Int?
  /// Bundled SMS messages per interval. null = unlimited.
  smsQuota        Int?
  /// When false, the tier is hidden from new sign-ups but existing schools keep it.
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@map("plans")
}

model Subscription {
  id                 String             @id @default(cuid())
  schoolId           String
  plan               SchoolPlan
  status             SubscriptionStatus @default(TRIALING)
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  paystackSubCode    String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@map("subscriptions")
}

// ─── Notification ────────────────────────────────────────────────────────────

model Notification {
  id        String              @id @default(cuid())
  schoolId  String
  userId    String
  channel   NotificationChannel
  status    NotificationStatus  @default(PENDING)
  title     String
  body      String
  data      Json                @default("{}")
  sentAt    DateTime?
  readAt    DateTime?
  createdAt DateTime            @default(now())

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([schoolId])
  @@index([status])
  @@map("notifications")
}

// ─── AuditLog ────────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  schoolId   String?
  userId     String?
  action     String
  resource   String
  resourceId String?
  meta       Json     @default("{}")
  ip         String?
  createdAt  DateTime @default(now())

  school School? @relation(fields: [schoolId], references: [id])
  user   User?   @relation(fields: [userId], references: [id])

  @@index([schoolId, createdAt(sort: Desc)])
  @@index([userId])
  @@index([resource, resourceId])
  @@map("audit_logs")
}
