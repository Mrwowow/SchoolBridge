# ─── Application ───────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://schoolbridge:schoolbridge@localhost:5432/schoolbridge"

# ─── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_ACCESS_SECRET=replace_me_access_secret
JWT_REFRESH_SECRET=replace_me_refresh_secret
# ISO duration strings
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Cloudinary (media attachments) ────────────────────────────────────────────
# Format: cloudinary://<api_key>:<api_secret>@<cloud_name>
CLOUDINARY_URL=cloudinary://your_api_key:your_api_secret@your_cloud_name

# ─── Termii (SMS / OTP) ────────────────────────────────────────────────────────
# TODO: sign up at https://termii.com and replace with real keys
TERMII_API_KEY=
TERMII_SENDER_ID=SchoolBridge
TERMII_BASE_URL=https://api.ng.termii.com

# ─── Expo Push Notifications ───────────────────────────────────────────────────
# TODO: configured per mobile app build — no server secret required for Expo managed workflow
EXPO_ACCESS_TOKEN=

# ─── Paystack (Payments) ───────────────────────────────────────────────────────
# TODO: obtain from https://dashboard.paystack.com/#/settings/developer
# PAYSTACK_SECRET_KEY is used for BOTH API calls and webhook HMAC verification —
# Paystack signs webhooks with the secret key, so no separate webhook secret.
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# ─── Resend (Transactional Email) ──────────────────────────────────────────────
# TODO: obtain from https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@schoolbridge.ng

# Set to "false" to run the API without Redis/queue workers (local dev)
NOTIFICATIONS_ENABLED=true
