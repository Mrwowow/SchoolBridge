# Copy to .env.local and fill in values.
# All EXPO_PUBLIC_ variables are inlined at build time and visible to the client.

# Base URL of the SchoolBridge REST API (no trailing slash)
EXPO_PUBLIC_API_URL=http://localhost:4000

# School tenant ID sent in the x-school-id header.
# In production this would be resolved from the login flow / deep-link.
EXPO_PUBLIC_SCHOOL_ID=

# Socket.IO namespace (matches backend /realtime)
EXPO_PUBLIC_SOCKET_PATH=/realtime
